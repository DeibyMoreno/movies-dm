# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/movies_dm_platform
DB_HOST=localhost
DB_PORT=5432
DB_NAME=movies_dm_platform
DB_USER=user
DB_PASSWORD=password

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-minimum-32-chars-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ──────────────────────────────────────────────
# Logger
# ──────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true
